# Local-dev env for `docker compose up`. Copy to .env and fill in. Never commit .env.
#
# Two categories below:
#   - RUNTIME    : read by the gateway at startup. Change -> just restart the
#                  container. On ROFL these come from `oasis rofl secret set`.
#   - BUILD-TIME : baked into the React login bundle by Vite. Change -> rebuild
#                  (`docker compose up --build`); a plain restart won't pick it up.

# ───────────────────────── RUNTIME (gateway) ─────────────────────────

# Comma-separated allowlist of Ethereum addresses (case-insensitive).
WALLET_WHITELIST=0xYourAddress1,0xYourAddress2

# Session-signing key. SECRET. MUST be stable and >= 32 chars. Generate with:
#   openssl rand -hex 32
WALLET_SESSION_SECRET=replace-with-openssl-rand-hex-32

# Public host the dashboard is served from (no scheme). For local dev use
# localhost; on ROFL set this to the proxy host (oasis rofl machine show).
WALLET_DOMAIN=localhost:8080

# Local dev over plain http needs Secure cookies OFF (production: leave true).
# COOKIE_SECURE=false

# Chain to accept SIWE messages from (1 = Ethereum mainnet). Also fed to the
# login bundle at build time (compose maps VITE_CHAIN_ID from this).
WALLET_CHAIN_ID=1

# ───────────────────────── BUILD-TIME (login bundle) ─────────────────────────

# Free id from https://cloud.reown.com. Enables WalletConnect / mobile-QR in the
# RainbowKit modal. NOT secret (it ships in the public client bundle). Injected
# wallets (MetaMask, Rabby, Coinbase ext) work without it. Requires --build.
VITE_WC_PROJECT_ID=
