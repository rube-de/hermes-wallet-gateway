# Dependencies
node_modules/

# Build output
dist/
*.tsbuildinfo

# Secrets & local env — NEVER commit these. Keep only the template.
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# ROFL manifest — generated by `oasis rofl init` (deployment-specific: app id,
# enclave hashes, deployments). Never hand-author or commit it here.
rofl.yaml
rofl.*.yaml

# Claude Code local state — keep only deliverables under .claude/files/
.claude/*
!.claude/files/
